@using GuildsApp.Web.Models.User
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <a href="/Feed/Index" class="auth-card__brand">Guildle</a>
            <div class="auth-card__subtitle">Create your account and join your first guild.</div>
        </div>

        <div class="auth-card__body">
            <h1 class="auth-title">Create account</h1>
            <p class="auth-text">Start posting, joining quests, and contributing to the community.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-validation-summary">
                    @Html.ValidationSummary(excludePropertyErrors: true, message: "Please correct the highlighted fields.")
                </div>
            }

            <form asp-action="Register" method="post" class="auth-form">
                <div class="form-group">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-input" autocomplete="username" />
                    <span asp-validation-for="Username" class="auth-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-input" autocomplete="name" />
                    <span asp-validation-for="DisplayName" class="auth-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-input" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="auth-validation"></span>
                </div>

                <div class="auth-actions">
                    <button type="submit" class="btn btn--primary">Create account</button>
                </div>
            </form>

            <div class="auth-switch">
                Already have an account?
                <a asp-action="Login">Login</a>
            </div>

            <div class="auth-secondary-actions">
                <a href="/Feed/Index">Continue as a guest</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
