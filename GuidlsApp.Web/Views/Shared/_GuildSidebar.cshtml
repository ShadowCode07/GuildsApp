@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

<aside class="nav-panel" aria-label="Navigation">
    <div class="nav-panel__section">
        <p class="nav-panel__label">@(Model.IsAuthenticated ? "Your guilds" : "Featured guilds")</p>

        <a href="/Feed/Index" class="nav-panel__link @(Model.IsGuildFeed ? "" : "is-active")">
            <div class="nav-panel__icon avatar avatar--sm avatar--blue">HF</div>
            <span>Home feed</span>
        </a>

        @if (Model.SidebarGuilds.Any())
        {
            @foreach (var guild in Model.SidebarGuilds)
            {
                var activeClass = Model.ActiveGuildSlug == guild.Slug ? "is-active" : "";

                <a href="/g/@guild.Slug" class="nav-panel__link @activeClass">
                    <div class="nav-panel__icon avatar avatar--sm avatar--blue">
                        @guild.Slug.Substring(0, Math.Min(2, guild.Slug.Length)).ToUpper()
                    </div>
                    <span>g/@guild.Slug</span>
                </a>
            }
        }
        else
        {
            <p class="nav-panel__note">
                @(Model.IsAuthenticated
                    ? "Join or create a guild to personalize your feed."
                    : "Browse public guilds and jump into a community that fits.")
            </p>
        }

        <a href="@(Model.IsAuthenticated ? "/Community/Create" : "/Account/Login")" class="nav-panel__link">
            <span>@(Model.IsAuthenticated ? "+ Create guild" : "Login to create a guild")</span>
        </a>
    </div>

    <div class="nav-panel__section">
        <p class="nav-panel__label">Navigate</p>

        <a href="/Feed/Index" class="nav-panel__link @(Model.IsGuildFeed ? "" : "is-active")">Feed</a>
        <a href="/Quest/Index" class="nav-panel__link">Quest board</a>
        <a href="/Profile/Index" class="nav-panel__link">Profile</a>
        <a href="/Community/Index" class="nav-panel__link">Discover guilds</a>
    </div>
</aside>
