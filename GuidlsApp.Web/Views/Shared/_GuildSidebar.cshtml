@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

<aside class="sidebar" aria-label="Navigation">
    <div class="sidebar__section">
        <p class="sidebar__label">My guilds</p>

        @foreach (var guild in Model.MyCommunities)
        {
            var activeClass = guild.IsActive ? "is-active" : "";

            <a href="/g/@guild.Slug" class="sidebar__item @activeClass">
                <div class="sidebar__item-icon avatar avatar--sm @guild.AvatarClass">
                    @guild.Initials
                </div>
                <span>g/@guild.Slug</span>
            </a>
        }

        <a href="/Community/Create" class="sidebar__item">
            <span>+ Create guild</span>
        </a>
    </div>

    <div class="sidebar__section">
        <p class="sidebar__label">Navigate</p>

        <a href="/Feed/Index" class="sidebar__item is-active">Feed</a>
        <a href="/Quest/Index" class="sidebar__item">Quest board</a>
        <a href="/Profile/Index" class="sidebar__item">Profile</a>
        <a href="/Community/Discover" class="sidebar__item">Discover guilds</a>
    </div>
</aside>