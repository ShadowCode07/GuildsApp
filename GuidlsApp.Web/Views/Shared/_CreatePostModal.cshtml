@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

<div class="dialog-shell" id="post-dialog" aria-hidden="true">
    <div class="dialog-shell__backdrop" data-action="close-create-modal"></div>

    <div class="dialog-panel" role="dialog" aria-modal="true" aria-labelledby="post-dialog-title">
        <div class="dialog-panel__header">
            <h2 id="post-dialog-title" class="dialog-panel__title">Create post</h2>

            <button type="button" class="dialog-panel__close" data-action="close-create-modal" aria-label="Close">
                &times;
            </button>
        </div>

        @if (Model.CanCreatePost)
        {
            <form id="post-form" class="composer">
                @Html.AntiForgeryToken()

                <div class="composer__row">
                    <div class="composer__group">
                        <label for="post-community" class="composer__label">Guild</label>

                        <select id="post-community" name="CommunityId" class="composer__select">
                            @foreach (var guild in Model.PostableGuilds)
                            {
                                if (Model.DefaultPostCommunityId == guild.Id)
                                {
                                    <option value="@guild.Id" selected>g/@guild.Slug</option>
                                }
                                else
                                {
                                    <option value="@guild.Id">g/@guild.Slug</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="composer__tabs">
                    <button type="button" class="composer__tab is-active">Text</button>
                </div>

                <div class="composer__field">
                    <input type="text"
                           name="Title"
                           class="composer__title-input"
                           maxlength="300"
                           placeholder="Title*" />
                    <div class="composer__counter">
                        <span id="post-title-counter">0</span>/300
                    </div>
                </div>

                <div class="composer__editor">
                    <textarea name="Body"
                              class="composer__textarea"
                              placeholder="Body text*"></textarea>
                </div>

                <div class="composer__actions">
                    <button type="button" class="btn btn--ghost" data-action="close-create-modal">Cancel</button>
                    <button type="submit" class="composer__submit">Post</button>
                </div>
            </form>
        }
        else
        {
            <div class="composer composer--empty">
                <p class="composer__note">
                    @(Model.IsAuthenticated
                        ? "Create or join a guild before posting so we know where your conversation belongs."
                        : "Login first, then join or create a guild to publish your first post.")
                </p>

                <div class="composer__actions">
                    @if (Model.IsAuthenticated)
                    {
                        <a href="/Community/Create" class="composer__submit">Create guild</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="composer__submit">Login</a>
                    }
                </div>
            </div>
        }
    </div>
</div>
