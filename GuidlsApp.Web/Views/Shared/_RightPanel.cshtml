@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

<aside class="side-panel">
    <section class="panel-card">
        <div class="panel-card__header">Feed context</div>

        <div class="panel-card__body">
            <p class="panel-card__text">@Model.FeedDescription</p>

            <div class="panel-card__list">
                <div class="panel-card__list-row">
                    <span class="panel-card__list-label">Scope</span>
                    <strong>@(Model.IsGuildFeed ? $"g/{Model.ActiveGuildSlug}" : "All public guilds")</strong>
                </div>

                <div class="panel-card__list-row">
                    <span class="panel-card__list-label">Posting</span>
                    <strong>@(Model.CanCreatePost ? "Available" : Model.IsAuthenticated ? "Create or join a guild first" : "Login required")</strong>
                </div>

                <div class="panel-card__list-row">
                    <span class="panel-card__list-label">Visible posts</span>
                    <strong>@Model.Posts.Count</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="panel-card">
        <div class="panel-card__header">Quick actions</div>

        <div class="panel-card__body panel-card__body--stack">
            @if (Model.CanCreatePost)
            {
                <button type="button" class="btn btn--primary panel-card__action" data-action="open-create-modal">Create a post</button>
            }
            else if (Model.IsAuthenticated)
            {
                <a href="/Community/Create" class="btn btn--primary panel-card__action">Create a guild</a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn--primary panel-card__action">Login</a>
                <a href="/Account/Register" class="btn btn--ghost panel-card__action">Create account</a>
            }
        </div>
    </section>
</aside>
