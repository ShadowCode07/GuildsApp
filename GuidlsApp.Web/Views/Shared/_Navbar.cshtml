@model GuildsApp.Web.ViewModels.Feed.FeedPageViewModel

<header class="topbar">
    <div class="topbar__brand">
        <a href="/feed" class="brand-link">Guildle</a>
    </div>

    <div class="topbar__search">
        <form method="get" action="/feed">
            <input type="text"
                   name="searchQuery"
                   value="@Model.SearchQuery"
                   class="search-input"
                   placeholder="Search guilds, posts, quests..." />
        </form>
    </div>

    <div class="topbar__actions">
        <a href="/profile" class="profile-pill">PD</a>
    </div>
</header>