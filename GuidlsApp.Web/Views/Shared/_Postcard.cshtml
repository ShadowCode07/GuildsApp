@model GuildsApp.Application.DTOs.FeedDTOs.FeedPostDto

<article class="post-card" data-post-id="@Model.Id">
    <div class="post-card__vote">
        <button type="button"
                class="post-card__vote-button post-card__vote-button--up @(Model.CurrentUserVote == 1 ? "is-voted" : "")"
                data-action="vote"
                data-value="1"
                aria-label="Upvote">
            ▲
        </button>
        <div class="post-card__vote-count">@Model.Score</div>
        <button type="button"
                class="post-card__vote-button post-card__vote-button--down @(Model.CurrentUserVote == -1 ? "is-voted" : "")"
                data-action="vote"
                data-value="-1"
                aria-label="Downvote">
            ▼
        </button>
    </div>

    <div class="post-card__body">
        <div class="post-card__meta">
            Posted by <a href="/u/@Model.AuthorUsername">u/@Model.AuthorUsername</a>
            in <a href="/g/@Model.CommunitySlug">g/@Model.CommunitySlug</a>
            · @Model.CreatedAt.ToLocalTime().ToString("g")

            @if (Model.IsPinned)
            {
                <span class="text-primary fw-500"> · Pinned</span>
            }
        </div>

        <h2 class="post-card__title">
            <a href="/Post/Details/@Model.Id">@Model.Title</a>
        </h2>

        <div class="post-card__footer">
            <a href="/Post/Details/@Model.Id" class="post-card__action">@Model.CommentCount comments</a>
            <button type="button" class="post-card__action" data-action="share" data-url="/Post/Details/@Model.Id">Share</button>
        </div>
    </div>
</article>
