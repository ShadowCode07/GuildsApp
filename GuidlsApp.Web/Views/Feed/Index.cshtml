@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

@{
    ViewData["Title"] = Model.FeedTitle;
}

<div class="app-shell">
    <partial name="_Topbar" model="Model" />

    <div class="app-layout">
        <partial name="_GuildSidebar" model="Model" />

        <main class="content-area">
            <section class="section-header section-header--feed">
                <div>
                    <p class="section-header__eyebrow">@(Model.IsGuildFeed ? "Guild feed" : "Public feed")</p>
                    <h1 class="section-header__title">@Model.FeedTitle</h1>
                    <p class="section-header__text">@Model.FeedDescription</p>
                </div>

                @if (Model.CanCreatePost)
                {
                    <button type="button" class="btn btn--primary" data-action="open-create-modal">Create post</button>
                }
                else if (Model.IsAuthenticated)
                {
                    <a href="/Community/Create" class="btn btn--primary">Create guild</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn--primary">Login to post</a>
                }
            </section>

            <div class="feed-toolbar">
                <button type="button" class="btn btn--ghost is-active" data-action="sort" data-sort="hot">Hot</button>
                <button type="button" class="btn btn--ghost" data-action="sort" data-sort="new">New</button>
                <button type="button" class="btn btn--ghost" data-action="sort" data-sort="top">Top</button>
                <div class="feed-toolbar__spacer"></div>
                <span class="feed-toolbar__meta">
                    @(Model.IsGuildFeed
                        ? "Only posts from this guild are shown."
                        : "Posts from public guilds appear here.")
                </span>
            </div>

            @if (Model.Posts.Any())
            {
                foreach (var post in Model.Posts)
                {
                    <partial name="_PostCard" model="post" />
                }
            }
            else
            {
                <div class="state-empty">
                    <h2 class="state-empty__title">No posts yet</h2>
                    <p class="state-empty__text">
                        @(Model.IsGuildFeed
                            ? "This guild does not have any posts yet. Be the first to start the conversation."
                            : "The public feed is quiet right now. Try another guild or create a post once you join one.")
                    </p>
                </div>
            }
        </main>

        <partial name="_RightPanel" model="Model" />
    </div>
</div>

<partial name="_CreatePostModal" model="Model" />
