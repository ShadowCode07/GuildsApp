@using GuildsApp.Web.Models.Feed
@model FeedPageViewModel

@{
    ViewData["Title"] = "Feed";
}

<div class="app-shell">
    @Html.Partial("_Topbar", Model)

    <div class="page-body">
        @Html.Partial("_GuildSidebar", Model)

        <main class="main-content">
            <div class="sort-bar">
                <button type="button" class="btn btn--ghost is-active" data-action="sort" data-sort="hot">Hot</button>
                <button type="button" class="btn btn--ghost" data-action="sort" data-sort="new">New</button>
                <button type="button" class="btn btn--ghost" data-action="sort" data-sort="top">Top</button>
                <div class="sort-bar__spacer"></div>
                <a href="/Post/Create" class="btn btn--primary">Create post</a>
            </div>

            @foreach (var post in Model.Posts)
            {
                @Html.Partial("_Postcard", post)
            }
        </main>

        @Html.Partial("_RightPanel", Model)
    </div>
</div>