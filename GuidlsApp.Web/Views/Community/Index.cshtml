@model IEnumerable<GuildsApp.Application.DTOs.CommunityDTOs.CommunityListItemDto>

@{
    ViewData["Title"] = "Discover guilds";
}

<div class="page-shell">
    <section class="section-header">
        <div>
            <p class="section-header__eyebrow">Discover</p>
            <h1 class="section-header__title">Find a guild to follow</h1>
            <p class="section-header__text">
                Browse communities, jump into a guild feed, and narrow your timeline to the conversations you care about.
            </p>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/Community/Create" class="btn btn--primary">Create guild</a>
        }
        else
        {
            <a href="/Account/Login" class="btn btn--primary">Login to create</a>
        }
    </section>

    @if (Model.Any())
    {
        <section class="collection-list">
            @foreach (var guild in Model.OrderBy(g => g.Name))
            {
                <article class="collection-card">
                    <div>
                        <p class="collection-card__meta">g/@guild.Slug</p>
                        <h2 class="collection-card__title">
                            <a href="/g/@guild.Slug">@guild.Name</a>
                        </h2>
                        <p class="collection-card__text">
                            @(string.IsNullOrWhiteSpace(guild.Description)
                                ? "No description has been added yet."
                                : guild.Description)
                        </p>
                    </div>

                    <a href="/g/@guild.Slug" class="btn btn--ghost">Open feed</a>
                </article>
            }
        </section>
    }
    else
    {
        <section class="state-empty">
            <h2 class="state-empty__title">No guilds yet</h2>
            <p class="state-empty__text">Create the first guild and start shaping the conversation.</p>
        </section>
    }
</div>
